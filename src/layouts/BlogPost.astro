---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, projectName, artist, genre, releaseDate, rating } = Astro.props;

// Check if we have any music-specific metadata
const hasMusicMeta = projectName || artist || genre || releaseDate || rating;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			/* Wide header section - matches nav width exactly */
			.post-hero {
				max-width: 1200px;
				margin: 0 auto 3rem;
				padding: 0 1.5rem;
			}

			/* Salient-style grid header */
			.post-header-grid {
				display: grid;
				grid-template-columns: 1fr 300px;
				gap: 4rem;
				align-items: end; /* Align grid to bottom of left column */
				margin-bottom: 3rem;
			}

			.post-header-left {
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
			}

			.post-label {
				font-size: 0.85rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: var(--green);
			}

			.post-title {
				font-size: clamp(2.5rem, 6vw, 4.5rem);
				line-height: 1.05;
				margin: 0;
				font-weight: 700;
				letter-spacing: -0.03em;
			}

			.post-description {
				font-size: 1.1rem;
				line-height: 1.6;
				color: var(--gray);
				max-width: 600px;
				margin: 0;
			}

			/* Right column metadata - 2x2 grid */
			.post-meta-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1.5rem 2rem;
				padding-bottom: 0.25rem; /* Fine-tune alignment with title */
			}

			.meta-section {
				display: flex;
				flex-direction: column;
				gap: 0.35rem;
			}

			.meta-label {
				font-size: 0.7rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: var(--green);
			}

			.meta-value {
				font-size: 1.1rem;
				font-weight: 500;
				color: var(--black);
				line-height: 1.3;
			}

			/* Rating display - much larger */
			.meta-section.rating-section .meta-value {
				font-size: 3.5rem;
				font-weight: 700;
				color: var(--black);
				font-family: 'Space Grotesk', sans-serif;
				line-height: 1;
				letter-spacing: -0.02em;
			}

			/* Hero image - full width */
			.hero-image-container {
				width: 100%;
				margin: 0 auto 3rem;
				max-width: 1200px;
				padding: 0 1.5rem;
			}

			.hero-image-container img {
				width: 100%;
				height: auto;
				border-radius: 8px;
				object-fit: cover;
				max-height: 600px;
			}

			/* Article content - narrower width */
			article {
				max-width: 720px;
				margin: 0 auto;
				padding: 0 1.5rem;
			}

			.prose {
				color: var(--black);
			}

			.prose h2 {
				margin-top: 2.5rem;
				margin-bottom: 1rem;
			}

			.prose h3 {
				margin-top: 2rem;
				margin-bottom: 0.75rem;
			}

			.prose a {
				text-decoration: underline;
				text-underline-offset: 2px;
			}

			.prose a:hover {
				text-decoration-thickness: 2px;
			}

			.prose img {
				border-radius: 8px;
				margin: 2rem 0;
			}

			.prose ul,
			.prose ol {
				margin: 1.5rem 0;
			}

			.back-link {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				margin-top: 3rem;
				padding: 0.75rem 1.25rem;
				background: var(--gray-lighter);
				border-radius: 4px;
				font-weight: 500;
				transition: all 0.2s ease;
			}

			.back-link:hover {
				background: var(--green);
				color: var(--white);
			}

			/* Simple header for posts without music metadata */
			.post-header-simple {
				max-width: 720px;
				margin: 0 auto 3rem;
				padding: 0 1.5rem;
			}

			.post-header-simple .post-meta {
				display: flex;
				gap: 1rem;
				flex-wrap: wrap;
				color: var(--gray);
				font-size: 0.95rem;
				margin-bottom: 1rem;
			}

			.post-header-simple h1 {
				font-size: clamp(2rem, 5vw, 3rem);
				margin-bottom: 0;
				line-height: 1.2;
			}

			.updated {
				font-style: italic;
			}

			/* Responsive */
			@media (max-width: 900px) {
				.post-header-grid {
					grid-template-columns: 1fr;
					gap: 2rem;
				}

				.post-meta-grid {
					grid-template-columns: 1fr 1fr;
				}

				.post-hero,
				.hero-image-container {
					padding: 0 1rem;
				}
			}

			@media (max-width: 768px) {
				.post-hero {
					margin-bottom: 2rem;
				}

				.post-header-grid {
					margin-bottom: 2rem;
				}

				.post-title {
					font-size: clamp(2rem, 8vw, 3rem);
				}

				.meta-value {
					font-size: 1rem;
				}

				.meta-section.rating-section .meta-value {
					font-size: 2.5rem;
				}

				article {
					padding: 0 1rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			{hasMusicMeta ? (
				<>
					{/* Wide grid header for music posts */}
					<div class="post-hero">
						<div class="post-header-grid">
							<div class="post-header-left">
								{projectName && <span class="post-label">{projectName}</span>}
								<h1 class="post-title">{title}</h1>
								{description && <p class="post-description">{description}</p>}
							</div>
							<div class="post-meta-grid">
								{/* Row 1: Rating (left), Artist (right) */}
								{rating && (
									<div class="meta-section rating-section">
										<span class="meta-label">Rating</span>
										<span class="meta-value">{rating}/10</span>
									</div>
								)}
								{artist && (
									<div class="meta-section">
										<span class="meta-label">Artist</span>
										<span class="meta-value">{artist}</span>
									</div>
								)}
								{/* Row 2: Genre (left), Release Date (right) */}
								{genre && (
									<div class="meta-section">
										<span class="meta-label">Genre</span>
										<span class="meta-value">{genre}</span>
									</div>
								)}
								{releaseDate && (
									<div class="meta-section">
										<span class="meta-label">Release Date</span>
										<span class="meta-value">{releaseDate}</span>
									</div>
								)}
							</div>
						</div>
					</div>

					{/* Full-width hero image */}
					{heroImage && (
						<div class="hero-image-container">
							<Image src={heroImage} alt={title} width={1200} height={600} />
						</div>
					)}
				</>
			) : (
				/* Simple header for non-music posts */
				<div class="post-header-simple">
					<div class="post-meta">
						<FormattedDate date={pubDate} />
						{updatedDate && (
							<span class="updated">
								Updated: <FormattedDate date={updatedDate} />
							</span>
						)}
					</div>
					<h1>{title}</h1>
				</div>
			)}

			{/* Narrow article content */}
			<article>
				<div class="prose">
					<slot />
				</div>
				<a href="/blog" class="back-link">
					<span aria-hidden="true">←</span> Back to all posts
				</a>
			</article>
		</main>
		<Footer />
	</body>
</html>
