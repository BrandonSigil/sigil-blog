---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import logoSrc from '../assets/sigil.svg';
import  SpeedInsights  from "@vercel/speed-insights/astro"
---

<header>
	<SpeedInsights />
	<nav>
		<a href="/" class="logo">
			<img src={logoSrc.src} alt={SITE_TITLE} />
		</a>
		<div class="nav-links">
			<HeaderLink href="/portfolio">Work</HeaderLink>
			<HeaderLink href="/blog">Music</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: rgba(247, 246, 241, 0.8);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1200px;
		margin: 0 auto;
		padding: 1rem 1.5rem;
		border-bottom: 2px solid var(--green);
	}

	.logo {
		display: flex;
		align-items: center;
		text-decoration: none;
	}

	.logo img {
		height: 2.5rem;
		width: auto;
	}

	.nav-links {
		display: flex;
		gap: 0.5rem;
	}

	@media (max-width: 768px) {
		nav {
			padding: 1rem;
		}

		.logo img {
			height: 2rem;
		}

		.nav-links {
			gap: 0.25rem;
		}
	}
</style>
