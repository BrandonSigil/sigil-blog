---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import logoSrc from '../assets/sigil-main.svg';
import  SpeedInsights  from "@vercel/speed-insights/astro"

interface Props {
	transparent?: boolean;
}

const { transparent = false } = Astro.props;
---

<header class:list={[{ transparent }]}>
	<SpeedInsights />
	<nav>
		<a href="/" class="logo">
			<img src={logoSrc.src} alt={SITE_TITLE} />
		</a>
		<div class="nav-links">
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/blog">Music</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		width: 100%;
		z-index: 100;
		background: rgba(247, 246, 241, 0.92);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		transition: background 0.4s ease, backdrop-filter 0.4s ease;
		--link-color: var(--green);
		--link-hover-bg: var(--gray-lighter);
		--link-hover-color: var(--green);
		--link-active-color: var(--green);
	}

	header.transparent {
		background: transparent;
		backdrop-filter: none;
		-webkit-backdrop-filter: none;
		--link-color: white;
		--link-hover-bg: rgba(255, 255, 255, 0.15);
		--link-hover-color: white;
		--link-active-color: white;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1200px;
		margin: 0 auto;
		padding: 1rem 1.5rem;
		border-bottom: 2px solid var(--green);
		transition: border-color 0.4s ease;
	}

	header.transparent nav {
		border-bottom-color: transparent;
	}

	.logo {
		display: flex;
		align-items: center;
		text-decoration: none;
	}

	.logo img {
		height: 2.5rem;
		width: auto;
		transition: filter 0.4s ease;
	}

	header.transparent .logo img {
		filter: brightness(0) invert(1);
	}

	.nav-links {
		display: flex;
		gap: 0.5rem;
	}

	@media (max-width: 768px) {
		nav {
			padding: 1rem;
		}

		.logo img {
			height: 2rem;
		}

		.nav-links {
			gap: 0.25rem;
		}
	}
</style>

<script>
	const header = document.querySelector('header') as HTMLElement;
	const hero = document.querySelector('.hero') as HTMLElement | null;

	if (hero) {
		document.body.classList.add('has-hero');

		const update = () => {
			header.classList.toggle('transparent', hero.getBoundingClientRect().bottom > 0);
		};

		window.addEventListener('scroll', update, { passive: true });
	}
</script>
