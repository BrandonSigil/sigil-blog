---
import type { ImageMetadata } from 'astro';
import ProjectImageSlider from './ProjectImageSlider.astro';

interface Props {
	eyebrow: string;
	title: string;
	description: string;
	images: ImageMetadata[];
	href?: string;
}

const { eyebrow, title, description, images, href } = Astro.props;
---

<article class="work-row">
	<div class="work-row-inner">
		<div class="work-copy">
			<p class="work-eyebrow">{eyebrow}</p>
			{
				href ? (
					<h2 class="work-title">
						<a href={href}>{title}</a>
					</h2>
				) : (
					<h2 class="work-title">{title}</h2>
				)
			}
			<p class="work-desc">{description}</p>
		</div>
		<div class="work-media">
			<ProjectImageSlider images={images} projectTitle={title} />
		</div>
	</div>
</article>

<style>
	.work-row {
		padding: 3rem 0;
		border-bottom: 2px solid var(--green);
	}

	.work-row:first-of-type {
		border-top: 2px solid var(--green);
	}

	.work-row-inner {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
		gap: clamp(2rem, 5vw, 4rem);
		align-items: start;
	}

	.work-copy {
		padding-top: 0.25rem;
		max-width: 36ch;
	}

	.work-eyebrow {
		margin: 0 0 0.75rem 0;
		font-size: 0.8125rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--gray);
	}

	.work-title {
		font-family: 'Space Grotesk', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
		font-size: clamp(1.75rem, 3.5vw, 2.75rem);
		font-weight: 700;
		color: var(--black);
		margin: 0 0 1rem 0;
		line-height: 1.12;
		letter-spacing: -0.02em;
	}

	.work-title a {
		color: inherit;
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.work-title a:hover {
		color: var(--green-dark);
	}

	.work-desc {
		margin: 0;
		font-size: 1.0625rem;
		line-height: 1.55;
		color: var(--gray);
		font-weight: 500;
	}

	.work-media {
		min-width: 0;
	}

	@media (max-width: 900px) {
		.work-row {
			padding: 2.25rem 0;
		}

		.work-row-inner {
			grid-template-columns: 1fr;
			gap: 1.75rem;
		}

		.work-copy {
			max-width: none;
		}
	}
</style>
