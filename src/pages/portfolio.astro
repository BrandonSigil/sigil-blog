---
import type { ImageMetadata } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import WorkProjectRow from '../components/WorkProjectRow.astro';
import { SITE_TITLE } from '../consts';

import nmfPoster from '../assets/nmf-04-24/nmf-04-24.jpg';
import nmfMatt from '../assets/nmf-04-24/matt-corby.webp';
import nmfSpotify from '../assets/nmf-04-24/spotify.jpg';
import nmfQuiet from '../assets/nmf-04-24/quiet-light.jpg';

import aboutCouple from '../assets/about/sigil-couple.jpg';
import aboutBrandon from '../assets/about/brandon-sigil.jpg';
import aboutAlex from '../assets/about/alex-sigil.jpg';

const projects: {
	eyebrow: string;
	title: string;
	description: string;
	images: ImageMetadata[];
	href?: string;
}[] = [
	{
		eyebrow: 'The Works',
		title: 'Noise Machine Festival',
		description:
			'Campaign site and rollout for a spring showcase—posters, socials, and a lineup page that stayed fast on spotty venue Wi‑Fi. We art-directed the hero and kept typography loud without fighting the photography.',
		images: [nmfPoster, nmfMatt, nmfSpotify, nmfQuiet],
		href: '/blog/new-music-friday-june-7',
	},
	{
		eyebrow: 'Brand Identity',
		title: 'Sigil Studio',
		description:
			'A mark and photo language for our own practice: simple geometry, warm film grain, and portraits that feel candid rather than corporate. Identity work you can actually live in day to day.',
		images: [aboutCouple, aboutBrandon, aboutAlex],
	},
	{
		eyebrow: 'Website',
		title: 'This very blog',
		description:
			'Astro, sharp images, and a layout that reads like a magazine. Built to ship quickly, stay accessible, and leave room for long-form writing without turning into a generic template.',
		images: [aboutBrandon, aboutAlex, aboutCouple],
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Work | ${SITE_TITLE}`} description="Selected projects from Sigil—websites, identity, and full-stack creative work." />
		<style>
			.work-page-header {
				margin-bottom: 0.5rem;
			}

			.work-page-header h1 {
				margin-bottom: 0.5rem;
			}

			.work-lede {
				margin: 0;
				max-width: 42ch;
				font-size: 1.125rem;
				color: var(--gray);
				line-height: 1.55;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<header class="work-page-header">
				<h1>Work</h1>
				<p class="work-lede">A few things we have shipped—each block is written to scan like a case study index, with imagery you can flick through.</p>
			</header>

			<section class="work-list" aria-label="Selected projects">
				{projects.map((p) => <WorkProjectRow {...p} />)}
			</section>
		</main>
		<Footer />
	</body>
</html>
