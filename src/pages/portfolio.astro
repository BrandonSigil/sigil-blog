---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const projects = [
	{
		title: 'Project One',
		description: 'A brief description of your first project. What technologies did you use? What problem did it solve?',
		tags: ['React', 'TypeScript', 'Node.js'],
		link: '#',
		image: null,
	},
	{
		title: 'Project Two',
		description: 'Another amazing project you worked on. Highlight the key features and your role.',
		tags: ['Python', 'Django', 'PostgreSQL'],
		link: '#',
		image: null,
	},
	{
		title: 'Project Three',
		description: 'A third project showcasing your diverse skills and creativity.',
		tags: ['Astro', 'CSS', 'JavaScript'],
		link: '#',
		image: null,
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Portfolio | ${SITE_TITLE}`} description="A collection of my work and projects" />
		<style>
			.page-header {
				text-align: center;
				margin-bottom: 3rem;
			}

			.page-header p {
				color: var(--gray);
				font-size: 1.25rem;
				max-width: 600px;
				margin: 1rem auto 0;
			}

			.projects-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
				gap: 2rem;
			}

			.project-card {
				background: var(--white);
				border: 2px solid var(--gray-light);
				border-radius: 8px;
				padding: 2rem;
				transition: all 0.2s ease;
			}

			.project-card:hover {
				border-color: var(--green);
				transform: translateY(-4px);
			}

			.project-card h3 {
				margin-bottom: 1rem;
			}

			.project-card p {
				color: var(--gray);
				margin-bottom: 1.5rem;
			}

			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				margin-bottom: 1.5rem;
			}

			.tag {
				background: var(--gray-lighter);
				color: var(--black);
				padding: 0.25rem 0.75rem;
				border-radius: 100px;
				font-size: 0.875rem;
				font-weight: 500;
			}

			.project-link {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				font-weight: 600;
			}

			.project-link:hover {
				gap: 0.75rem;
			}

			@media (max-width: 768px) {
				.projects-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Portfolio</h1>
				<p>A collection of projects I've worked on. Each one represents a unique challenge and learning experience.</p>
			</div>

			<div class="projects-grid">
				{projects.map((project) => (
					<article class="project-card">
						<h3>{project.title}</h3>
						<p>{project.description}</p>
						<div class="tags">
							{project.tags.map((tag) => (
								<span class="tag">{tag}</span>
							))}
						</div>
						<a href={project.link} class="project-link">
							View Project <span aria-hidden="true">→</span>
						</a>
					</article>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>
