---
import type { ImageMetadata } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import FeaturedCard from '../components/FeaturedCard.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const projects = [
	{
		title: 'Project One',
		subtitle: 'Client Name',
		description: 'A brief description of your first project. What technologies did you use? What problem did it solve?',
		tags: ['React', 'TypeScript', 'Node.js'],
		link: '#',
		image: undefined as ImageMetadata | undefined,
	},
	{
		title: 'Project Two',
		subtitle: 'Client Name',
		description: 'Another amazing project you worked on. Highlight the key features and your role.',
		tags: ['Python', 'Django', 'PostgreSQL'],
		link: '#',
		image: undefined as ImageMetadata | undefined,
	},
	{
		title: 'Project Three',
		subtitle: 'Client Name',
		description: 'A third project showcasing your diverse skills and creativity.',
		tags: ['Astro', 'CSS', 'JavaScript'],
		link: '#',
		image: undefined as ImageMetadata | undefined,
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Portfolio | ${SITE_TITLE}`} description="A collection of my work and projects" />
		<style>
			.page-header {
				text-align: center;
				margin-bottom: 3rem;
			}

			.page-header p {
				color: var(--gray);
				font-size: 1.25rem;
				max-width: 600px;
				margin: 1rem auto 0;
			}

			.projects-list {
				margin-bottom: 2rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Work</h1>
			</div>

			<div class="projects-list">
				{projects.map((project, index) => (
					<FeaturedCard
						title={project.title}
						subtitle={project.subtitle}
						description={project.description}
						href={project.link}
						image={project.image}
						imageAlt={project.title}
						tags={project.tags}
						reverse={index % 2 === 1}
					/>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>
