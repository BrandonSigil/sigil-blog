---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import FeaturedCard from '../components/FeaturedCard.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, SITE_AUTHOR } from '../consts';

const recentPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				min-height: 60vh;
				display: flex;
				flex-direction: column;
				justify-content: center;
				padding: 4rem 0;
			}

			.hero .tagline {
				font-size: clamp(1.25rem, 3vw, 1.75rem);
				color: var(--gray);
				margin-bottom: 2rem;
				max-width: 600px;
			}

			.hero-cta {
				display: flex;
				gap: 1rem;
				flex-wrap: wrap;
			}

			.section-header {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				margin-bottom: 2rem;
				flex-wrap: wrap;
				gap: 1rem;
			}

			.section-header h2 {
				margin: 0;
			}

			.section-header a {
				font-weight: 600;
			}

			.featured-posts {
				margin-bottom: 2rem;
			}

			.about-section {
				background: transparent;
				border: 2px solid var(--green);
				border-radius: 8px;
				padding: 2.5rem;
			}

			.about-section p {
				margin-bottom: 1.5rem;
				max-width: 700px;
			}

			.about-section p:last-of-type {
				margin-bottom: 0;
			}

			@media (max-width: 768px) {
				.hero {
					min-height: 50vh;
					padding: 3rem 0;
				}

				.post-card {
					padding: 1.25rem;
				}

				.about-section {
					padding: 1.5rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="tagline">
					Developer, designer, and music enthusiast. I write about the sounds that move me and the code that keeps me busy.
				</p>
				<div class="hero-cta">
					<a href="/blog" class="btn">Read the Blog</a>
					<a href="/portfolio" class="btn btn-outline">View Portfolio</a>
				</div>
			</section>

			<section>
				<div class="section-header">
					<h2>Recent Posts</h2>
					<a href="/blog">View all posts →</a>
				</div>
				<div class="featured-posts">
					{recentPosts.map((post, index) => (
						<FeaturedCard
							title={post.data.title}
							subtitle={post.data.pubDate.toLocaleDateString('en-us', { year: 'numeric', month: 'short', day: 'numeric' })}
							href={`/blog/${post.id}/`}
							image={post.data.heroImage?.src}
							imageAlt={post.data.title}
							reverse={index % 2 === 1}
						/>
					))}
				</div>
			</section>

			<section class="about-section">
				<h2>About Me</h2>
				<p>
					I'm {SITE_AUTHOR}, a software developer with a passion for clean design and great music.
					This site is where I share my thoughts on albums, artists, and the creative process.
				</p>
				<p>
					When I'm not coding, you'll find me digging through record stores or discovering new sounds.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>
