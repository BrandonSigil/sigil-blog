---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import FeaturedCard from '../components/FeaturedCard.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, SITE_AUTHOR } from '../consts';
import heroLogo from '../assets/sigil-main.svg';

const recentPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				position: relative;
				height: 100vh;
				width: 100%;
				margin-top: 0;
			}

			/* Noise layer between scene and logo */
			.hero::after {
				content: '';
				position: absolute;
				inset: 0;
				z-index: 5;
				background-image: url('/noise-sigil-white.png');
				background-repeat: repeat;
				background-size: auto;
				opacity: 0.3;
				pointer-events: none;
				mix-blend-mode: screen;
			}

			.hero-logo {
				position: absolute;
				top: 50%;
				left: 50%;
				transform: translate(-50%, -50%);
				z-index: 10;
				width: clamp(280px, 40vw, 520px);
				height: auto;
				filter: brightness(0) invert(1);
				pointer-events: none;
			}

			.section-header {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				margin-bottom: 2rem;
				flex-wrap: wrap;
				gap: 1rem;
			}

			.section-header h2 {
				margin: 0;
			}

			.section-header a {
				font-weight: 600;
			}

			.featured-posts {
				margin-bottom: 2rem;
			}

			.about-section {
				background: transparent;
				border: 2px solid var(--green);
				border-radius: 8px;
				padding: 2.5rem;
			}

			.about-section p {
				margin-bottom: 1.5rem;
				max-width: 700px;
			}

			.about-section p:last-of-type {
				margin-bottom: 0;
			}

			@media (max-width: 768px) {
				.about-section {
					padding: 1.5rem;
				}
			}
		</style>
	</head>
	<body>
		<Header transparent={true} />

		<section class="hero">
			<div data-us-project="iIayA4bIeBzePlqd5Bab" style="width: 100%; height: 100vh;"></div>
			<img src={heroLogo.src} alt={SITE_TITLE} class="hero-logo" />
		</section>

		<main>
			<section>
				<div class="section-header">
					<h2>Music News & Reviews</h2>
					<a href="/blog">View all posts →</a>
				</div>
				<div class="featured-posts">
					{recentPosts.map((post, index) => (
						<FeaturedCard
							title={post.data.title}
							subtitle={post.data.artist}
							description={post.data.description}
							href={`/blog/${post.id}`}
							image={post.data.heroImage}
							imageAlt={post.data.title}
							reverse={index % 2 === 1}
						/>
					))}
				</div>
			</section>

			<section class="about-section">
				<h2>About Me</h2>
				<p>
					I'm {SITE_AUTHOR}, a software developer with a passion for clean design and great music.
					This site is where I share my thoughts on albums, artists, and the creative process.
				</p>
				<p>
					When I'm not coding, you'll find me digging through record stores or discovering new sounds.
				</p>
			</section>
		</main>
		<Footer />

		<script is:inline>!function(){var u=window.UnicornStudio;if(u&&u.init){if(document.readyState==="loading"){document.addEventListener("DOMContentLoaded",function(){u.init()})}else{u.init()}}else{window.UnicornStudio={isInitialized:!1};var i=document.createElement("script");i.src="https://cdn.jsdelivr.net/gh/hiunicornstudio/unicornstudio.js@v2.1.11/dist/unicornStudio.umd.js",i.onload=function(){if(document.readyState==="loading"){document.addEventListener("DOMContentLoaded",function(){UnicornStudio.init()})}else{UnicornStudio.init()}},(document.head||document.body).appendChild(i)}}();</script>
	</body>
</html>
