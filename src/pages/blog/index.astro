---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import FeaturedCard from '../../components/FeaturedCard.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog | ${SITE_TITLE}`} description="Thoughts on music, albums, and the sounds that move me" />
		<style>
			.section-header {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				margin-bottom: 2rem;
				flex-wrap: wrap;
				gap: 1rem;
			}

			.section-header h1 {
				margin: 0;
			}

			.section-header p {
				color: var(--gray);
				font-size: 1.1rem;
				margin: 0;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="section-header">
				<h1>Music News & Reviews</h1>
			</div>

			<div class="posts-list">
				{posts.map((post, index) => (
					<FeaturedCard
						title={post.data.title}
						subtitle={post.data.artist}
						description={post.data.description}
						href={`/blog/${post.id}/`}
						image={post.data.heroImage}
						imageAlt={post.data.title}
						reverse={index % 2 === 1}
					/>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>
